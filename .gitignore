# Kubernetes
kubeconfig
*.kubeconfig
kubeconfig.*

# ArgoCD local credentials
argocd-initial-admin-secret.yaml

# Env files
.env
.env.*
!.env.example

# Logs
*.log

# Python (if any scripts)
__pycache__/
*.pyc
.venv/

# Node (if any tooling)
node_modules/
